<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Activity-level theme. The Compose layer drives all visual styling via
         StackcasinoTheme; this XML theme exists for the window background,
         system bars and the brief frame before setContent installs Compose. -->
    <style name="Theme.Stackcasino" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/stackcasino_window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen theme applied to MainActivity at boot.
         Inherits from Theme.SplashScreen so the AndroidX core-splashscreen
         backport stays consistent with the API 31+ platform behavior:
         brand-colored background, centered icon, then a fade-out into
         postSplashScreenTheme once the activity is ready. -->
    <style name="Theme.Stackcasino.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/stackcasino_window_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_brand_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Stackcasino</item>
    </style>
</resources>
