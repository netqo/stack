<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Activity-level theme. The Compose layer drives all visual styling via
         StackcasinoTheme; this XML theme exists for the window background,
         system bars and the brief frame before setContent installs Compose. -->
    <style name="Theme.Stackcasino" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/stackcasino_window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
